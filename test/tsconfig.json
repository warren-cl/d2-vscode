{
  "compilerOptions": {
    "module": "commonjs",
    "target": "ES2020",
    "strict": true,
    "sourceMap": true,
    "outDir": "../out/test",
    "rootDir": "..",
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "types": ["mocha", "node"]
  },
  "include": ["./**/*.ts", "../src/**/*.ts"],
  "exclude": ["../node_modules"]
}
